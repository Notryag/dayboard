DAYBOARD_ENV=local
DATABASE_URL=postgresql+asyncpg://dayboard:dayboard@localhost:5432/dayboard
POSTGRES_DB=dayboard
POSTGRES_USER=dayboard
POSTGRES_PASSWORD=dayboard
REDIS_URL=redis://localhost:6379/0
DAYBOARD_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DAYBOARD_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000002
DAYBOARD_DEFAULT_TIMEZONE=Asia/Shanghai
DAYBOARD_DEFAULT_LOCALE=zh-CN

# OpenAI-compatible model gateway. Put real secrets only in .env, never in git.
APP_MODEL_NAME=openai:gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_API_KEY=

# API boundary rate limiting. Use Redis or Valkey in shared/server environments.
DAYBOARD_RATE_LIMIT_ENABLED=true
DAYBOARD_RATE_LIMIT_DEFAULT=120/minute
DAYBOARD_RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1
